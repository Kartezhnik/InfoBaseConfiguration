// ================================================
// ПУНКТ 5 — Создание структуры
// ================================================
Функция СоздатьСтруктуруПользователей() Экспорт
    
    МассивДанных = Новый Массив;
    Выборка = Справочники.Пользователи.Выбрать();
    
    Пока Выборка.Следующий() Цикл
        Данные = Новый Структура;
        Данные.Вставить("Код",      Выборка.Код);
        Данные.Вставить("Фамилия",  Выборка.Фамилия);
        Данные.Вставить("Имя",      Выборка.Имя);
        
        МассивДанных.Добавить(Данные);
    КонецЦикла;
    
    Возврат МассивДанных;
    
КонецФункции

// ================================================
// ПУНКТ 6 — Обработка структуры
// ================================================
Процедура ОбработатьСтруктуруПользователей(ДанныеСтруктуры) Экспорт
    
    Если ДанныеСтруктуры = Неопределено ИЛИ ДанныеСтруктуры.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    
    Сообщить("Элементов до обработки: " + ДанныеСтруктуры.Количество());
    
    МаксДлина = -1;
    Лучший = Неопределено;
    
    Для Каждого Эл Из ДанныеСтруктуры Цикл
        Длина = СтрДлина(Эл.Фамилия) + СтрДлина(Эл.Имя);
        Если Длина > МаксДлина Тогда
            МаксДлина = Длина;
            Лучший = Эл;
        КонецЕсли;
    КонецЦикла;
    
    Если Лучший <> Неопределено Тогда
        Сообщить("Самый длинный ФИО: " + Лучший.Фамилия + " " + Лучший.Имя + " (" + МаксДлина + ")");
    КонецЕсли;
    
    ПоследнийИндекс = ДанныеСтруктуры.ВГраница();
    Последний = ДанныеСтруктуры[ПоследнийИндекс];
    ДанныеСтруктуры.Удалить(ПоследнийИндекс);
    
    Сообщить("Удалён из массива: " + Последний.Фамилия);
    
КонецПроцедуры

// ================================================
// ПУНКТ 7 — Пользователи без отчества
// ================================================
Функция ПолучитьПользователейБезОтчества() Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	Пользователи.Код КАК Код,
    |	Пользователи.Фамилия КАК Фамилия,
    |	Пользователи.Имя КАК Имя
    |ИЗ
    |	Справочник.Пользователи КАК Пользователи
    |ГДЕ
    |	Пользователи.Отчество = """"
    |УПОРЯДОЧИТЬ ПО
    |	Пользователи.Фамилия";
    
    Возврат Запрос.Выполнить().Выгрузить(); 
КонецФункции