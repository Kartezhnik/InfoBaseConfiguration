&НаКлиенте
Процедура ПоменятьИмяИОтчество(Команда)
    ПоменятьИмяИОтчествоНаСервере();
    Элементы.Список.Обновить();
    Сообщить("Имя и отчество успешно поменяны местами у всех пользователей.");
КонецПроцедуры

&НаСервере
Процедура ПоменятьИмяИОтчествоНаСервере()
    
    Выборка = Справочники.Пользователи.Выбрать();
    
    Пока Выборка.Следующий() Цикл
        Если ЗначениеЗаполнено(Выборка.Имя) И ЗначениеЗаполнено(Выборка.Отчество) Тогда
            
            ОбъектПользователь = Выборка.ПолучитьОбъект();
            
            ВременноеИмя = ОбъектПользователь.Имя;
            ОбъектПользователь.Имя = ОбъектПользователь.Отчество;
            ОбъектПользователь.Отчество = ВременноеИмя;
            
            Попытка
                ОбъектПользователь.Записать();
            Исключение
                Сообщить("Ошибка при записи пользователя " + ОбъектПользователь.Наименование + ": " + ОписаниеОшибки());
            КонецПопытки;
            
        КонецЕсли;
    КонецЦикла;
    
КонецПроцедуры